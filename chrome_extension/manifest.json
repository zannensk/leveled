{
    "manifest_version": 3,
    "name": "Task Overlay Tracker",
    "version": "1.0",
    "description": "Tracks active time on specific sites for the Task Overlay app.",
    "permissions": [
        "tabs",
        "idle",
        "alarms"
    ],
    "host_permissions": [
        "<all_urls>",
        "http://127.0.0.1:5123/*"
    ],
    "background": {
        "service_worker": "service_worker.js"
    }
}